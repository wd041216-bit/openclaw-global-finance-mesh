# For external-pilot deployment defaults, see .env.pilot.example
OLLAMA_MODE=local
OLLAMA_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CLOUD_BASE_URL=https://ollama.com
FINANCE_MESH_CLOUD_API_FLAVOR=auto
OLLAMA_API_KEY=
FINANCE_MESH_PORT=3030
# Audit source of truth is data/audit/ledger.sqlite. Legacy runs.json/activity.json are migrated once if present.
FINANCE_MESH_ENVIRONMENT=local
FINANCE_MESH_TEAM_SCOPE=default
FINANCE_MESH_AUDIT_EXPORT_DIR=
FINANCE_MESH_AUDIT_VERIFY_WARN_HOURS=24
FINANCE_MESH_AUTH_ENABLED=false
FINANCE_MESH_ALLOW_LOCAL_TOKENS=true
FINANCE_MESH_BOOTSTRAP_ADMIN_NAME=
FINANCE_MESH_BOOTSTRAP_ADMIN_TOKEN=
FINANCE_MESH_BASE_URL=
FINANCE_MESH_OIDC_ISSUER=
FINANCE_MESH_OIDC_CLIENT_ID=
FINANCE_MESH_OIDC_CLIENT_SECRET=
FINANCE_MESH_OIDC_SCOPES=openid profile email
FINANCE_MESH_OIDC_REDIRECT_PATH=/api/access-control/callback
FINANCE_MESH_COOKIE_SECURE=
FINANCE_MESH_LOG_FORMAT=pretty
FINANCE_MESH_BACKUP_LOCAL_DIR=
FINANCE_MESH_BACKUP_INTERVAL_MINUTES=
FINANCE_MESH_BACKUP_S3_ENDPOINT=
FINANCE_MESH_BACKUP_S3_REGION=
FINANCE_MESH_BACKUP_S3_BUCKET=
FINANCE_MESH_BACKUP_S3_PREFIX=
FINANCE_MESH_BACKUP_S3_ACCESS_KEY_ID=
FINANCE_MESH_BACKUP_S3_SECRET_ACCESS_KEY=
FINANCE_MESH_BACKUP_S3_FORCE_PATH_STYLE=false
FINANCE_MESH_RESTORE_DRILL_RETENTION_DAYS=7
FINANCE_MESH_RESTORE_DRILL_WARN_HOURS=168
