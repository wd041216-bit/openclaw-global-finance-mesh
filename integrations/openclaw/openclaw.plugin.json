{
  "id": "zhouheng-global-finance-mesh",
  "name": "Zhouheng Global Finance Mesh",
  "version": "0.4.0",
  "description": "OpenClaw plugin adapter for Zhouheng Global Finance Mesh with unified finance pack validation, decision packets, and replay analysis.",
  "skills": [
    "./skills"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "prependSystemGuidance": {
        "type": "boolean",
        "default": true
      },
      "defaultMode": {
        "type": "string",
        "enum": [
          "L0",
          "L1",
          "L2",
          "L3"
        ],
        "default": "L1"
      },
      "maxAutoExecuteRisk": {
        "type": "string",
        "enum": [
          "low",
          "medium",
          "high",
          "critical"
        ],
        "default": "low"
      },
      "packRoots": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "default": [
          "./examples/packs"
        ]
      }
    }
  }
}
