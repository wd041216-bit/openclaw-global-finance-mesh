{
  "name": "@wd041216-bit/zhouheng-global-finance-mesh",
  "version": "0.4.0",
  "private": false,
  "description": "Enterprise beta finance control plane with OIDC-ready sessions, audit ledger integrity, decision replay, and legal-library grounding.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    ".env.example",
    ".env.pilot.example",
    "desktop",
    "src",
    "web",
    "data",
    "examples",
    "docs",
    "integrations",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "node src/server.ts",
    "start": "node src/server.ts",
    "build:macos-installer": "node scripts/build-macos-installer.ts",
    "build:windows-package": "node scripts/build-windows-package.ts",
    "build:desktop-packages": "npm run build:macos-installer && npm run build:windows-package",
    "mcp:serve": "node integrations/mcp/server.ts",
    "test": "node --test tests/*.test.ts",
    "verify": "npm test",
    "verify:server": "node scripts/verify-server.ts",
    "verify:cloud-provider": "node scripts/smoke-cloud.ts",
    "verify:manifests": "node scripts/verify-manifests.ts",
    "review:pilot": "node scripts/review-pilot.ts",
    "doctor:hosts": "node scripts/doctor-hosts.ts",
    "doctor:cloud": "node scripts/smoke-cloud.ts",
    "smoke:mcp": "node scripts/smoke-mcp.ts",
    "smoke:openclaw": "node scripts/smoke-openclaw.ts",
    "smoke:cloud": "node scripts/smoke-cloud.ts",
    "smoke:restore": "node scripts/smoke-restore.ts",
    "smoke:ui": "node scripts/smoke-ui.ts",
    "smoke:pages": "node scripts/smoke-pages.ts",
    "smoke:release-artifacts": "node scripts/smoke-release-artifacts.ts",
    "release:check": "node scripts/release-check.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.910.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.8.1"
  },
  "homepage": "https://github.com/wd041216-bit/zhouheng-global-finance-mesh",
  "repository": {
    "type": "git",
    "url": "https://github.com/wd041216-bit/zhouheng-global-finance-mesh.git"
  },
  "keywords": [
    "finance",
    "control-plane",
    "audit-trail",
    "audit-ledger",
    "oidc",
    "rbac",
    "sqlite",
    "rule-engine",
    "decision-packet",
    "legal-library",
    "replay-analysis",
    "global-finance"
  ],
  "devDependencies": {
    "playwright": "^1.58.2"
  }
}
